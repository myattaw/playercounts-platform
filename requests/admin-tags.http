### Login
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "password"
}

> {%
    client.global.set(
        "auth_token",
        response.body.token
    );
%}

###

### Create Survival Tag
POST http://localhost:8080/admin/tags
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "name": "Survival",
  "color": "#22c55e"
}

